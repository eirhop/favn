# Image references should be immutable registry digests.
FAVN_CONTROL_PLANE_IMAGE=ghcr.io/example/favn-control-plane@sha256:...
FAVN_RUNNER_IMAGE=ghcr.io/example/customer-favn-runner@sha256:...
FAVN_CUSTOMER_APP=my_app

# PostgreSQL is external. Do not add a database service to this example.
FAVN_DATABASE_URL=ecto://runtime-user:password@postgres.example.internal/favn
# This portable example does not guess how your platform mounts secrets.
# For production, prefer verify-full and mount a CA file into the control plane.
FAVN_DATABASE_SSL_MODE=disable
FAVN_DATABASE_SSL_CA_FILE=

# Supply these through your deployment platform's secret store.
FAVN_RUNTIME_INPUT_PIN_KEYS={"1":"base64-encoded-32-byte-key"}
FAVN_RUNTIME_INPUT_PIN_KEY_VERSION=1
FAVN_ORCHESTRATOR_API_SERVICE_TOKENS=deployer-v1|platform_admin:replace-with-strong-token
FAVN_ORCHESTRATOR_BOOTSTRAP_USERNAME=admin
FAVN_ORCHESTRATOR_BOOTSTRAP_PASSWORD=replace-with-strong-password
FAVN_DISTRIBUTION_COOKIE=replace-with-high-entropy-cookie
FAVN_VIEW_SECRET_KEY_BASE=replace-with-at-least-64-bytes

FAVN_WORKSPACE_IDS=customer
FAVN_VIEW_PUBLIC_ORIGIN=https://favn.example.com
FAVN_VIEW_TRUSTED_PROXY_CIDRS=10.0.0.0/8
