{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://favn.dev/contracts/orchestrator/v1/coverage-baseline.schema.json",
  "title": "CoverageBaseline",
  "type": "object",
  "required": [
    "baseline_id",
    "pipeline_module",
    "source_key",
    "segment_key_hash",
    "window_kind",
    "timezone",
    "coverage_until",
    "created_by_run_id",
    "manifest_version_id",
    "status",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": true,
  "properties": {
    "baseline_id": { "type": "string", "minLength": 1 },
    "pipeline_module": { "type": "string", "minLength": 1 },
    "source_key": { "type": "string", "minLength": 1 },
    "segment_key_hash": { "type": "string", "minLength": 1 },
    "window_kind": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string", "minLength": 1 },
    "coverage_until": { "type": "string", "minLength": 1 },
    "created_by_run_id": { "type": "string", "minLength": 1 },
    "manifest_version_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
