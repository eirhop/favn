{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://favn.dev/contracts/orchestrator/v1/run-detail.schema.json",
  "title": "RunDetail",
  "type": "object",
  "required": [
    "id",
    "status",
    "submit_kind",
    "manifest_version_id",
    "manifest_content_hash",
    "event_seq",
    "started_at",
    "finished_at",
    "timeout_ms",
    "retry_backoff_ms",
    "rerun_of_run_id",
    "parent_run_id",
    "root_run_id",
    "target_refs",
    "params",
    "trigger",
    "metadata",
    "result",
    "pipeline",
    "pipeline_context",
    "asset_results",
    "node_results",
    "error"
  ],
  "additionalProperties": false,
  "$defs": {
    "assetResult": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "asset_ref": { "type": ["string", "null"] },
        "stage": { "type": ["integer", "null"], "minimum": 0 },
        "status": { "type": ["string", "null"] },
        "started_at": { "type": ["string", "null"] },
        "finished_at": { "type": ["string", "null"] },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "meta": {},
        "error": {},
        "attempt_count": { "type": ["integer", "null"], "minimum": 0 },
        "max_attempts": { "type": ["integer", "null"], "minimum": 0 },
        "attempts": {},
        "next_retry_at": { "type": ["string", "null"] }
      }
    },
    "nodeResult": {
      "type": "object",
      "required": ["node_key", "result"],
      "additionalProperties": false,
      "properties": {
        "node_key": {},
        "result": { "$ref": "#/$defs/assetResult" }
      }
    }
  },
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "submit_kind": { "type": "string", "minLength": 1 },
    "manifest_version_id": { "type": "string", "minLength": 1 },
    "manifest_content_hash": { "type": ["string", "null"] },
    "event_seq": { "type": "integer", "minimum": 1 },
    "started_at": { "type": ["string", "null"] },
    "finished_at": { "type": ["string", "null"] },
    "timeout_ms": { "type": ["integer", "null"], "minimum": 0 },
    "retry_backoff_ms": { "type": ["integer", "null"], "minimum": 0 },
    "rerun_of_run_id": { "type": ["string", "null"] },
    "parent_run_id": { "type": ["string", "null"] },
    "root_run_id": { "type": ["string", "null"] },
    "target_refs": { "type": "array", "items": { "type": "string" } },
    "params": {},
    "trigger": {},
    "metadata": {},
    "result": {},
    "pipeline": {},
    "pipeline_context": {},
    "asset_results": { "type": "array", "items": { "$ref": "#/$defs/assetResult" } },
    "node_results": { "type": "array", "items": { "$ref": "#/$defs/nodeResult" } },
    "error": {}
  }
}
