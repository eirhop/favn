{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "svelte": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sveltejs/mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "storybook": {
      "type": "remote",
      "url": "http://localhost:6006/mcp"
    }
  }
}